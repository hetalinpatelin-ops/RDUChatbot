# .env.example - Rename to .env and fill in your values
# This file is in .gitignore and will not be committed to GitHub

# Google Gemini API (optional)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your-google-api-key-here"

# Local LLM Configuration (optional)
# For Ollama: http://localhost:11434/v1
# For LM Studio: http://localhost:1234/v1
LOCAL_LLM_API_KEY="ollama"  # or your local LLM key
LOCAL_LLM_BASE_URL="http://localhost:11434/v1"

# Google Drive OAuth (optional)
# Path to your OAuth token (generated by setup script)
GOOGLE_TOKEN_PATH="C:/Users/Hetal/AppData/Local/hermes/google_token.json"